/* Üzv 3 - Haqqımızda CSS */

.about {
  display: grid;
  grid-template-columns: 2fr 1fr;
  align-items: center;
  gap: 28px;
}

.about .section-title {
  text-align: left;
  margin-bottom: 18px;
}

.about-text,
.about-box {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 28px;
  box-shadow: 0 8px 22px rgba(15, 42, 68, 0.08);
}

.about-box {
  border-left: 5px solid #1d5b89;
}

.about-box h3 {
  color: #0f2a44;
  margin-bottom: 10px;
}
